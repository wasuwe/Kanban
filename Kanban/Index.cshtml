  if(p.columns.length<=1){toast('ต้องมีอย่างน้อย 1 คอลัมน์');return;}
  const c=p.columns.find(x=>x.id===id);
  if(!confirm(`ลบคอลัมน์ "${c.name}"? งานที่อยู่ในนี้จะถูกย้ายไปคอลัมน์แรก`)) return;
  const fallback=p.columns.find(x=>x.id!==id).id;
  state.tasks.forEach(t=>{ if(t.projectId===p.id&&t.status===id)t.status=fallback; });
  p.columns=p.columns.filter(x=>x.id!==id);
  closePopover(); renderAll();
  try{ await apply('deleteColumn',{ id:id, fallbackId:fallback }); toast('ลบคอลัมน์แล้ว'); }catch(e){}
}

/* --- Generic popover --- */
function openPopover(anchor, html){
  const pop=$('#popover'); pop.innerHTML=html;
  pop.classList.add('open'); $('#popScrim').classList.add('open');
  const r=anchor.getBoundingClientRect();
  pop.style.visibility='hidden';
  // measure then place
  requestAnimationFrame(()=>{
    const pw=pop.offsetWidth, ph=pop.offsetHeight, m=8;
    let left=r.left, top=r.bottom+6;
    if(left+pw > window.innerWidth-m) left=window.innerWidth-pw-m;
    if(left<m) left=m;
    if(top+ph > window.innerHeight-m) top=r.top-ph-6;
    pop.style.left=left+'px'; pop.style.top=Math.max(m,top)+'px';
    pop.style.visibility='visible';
  });
}
function closePopover(){ $('#popover').classList.remove('open'); $('#popScrim').classList.remove('open'); }

/* ========================================================
   CATEGORIES
   ======================================================== */
function openCategoryModal(){ renderCategoryModal(); }
function renderCategoryModal(){
  const p=activeProject();
  const rows=p.categories.map(c=>{
    const used=state.tasks.filter(t=>t.projectId===p.id&&t.categoryId===c.id).length;
    return `<div class="cat-row">
      <span class="cat-swatch" style="background:${c.color};cursor:pointer" onclick="cycleCatColor('${c.id}')" title="เปลี่ยนสี"></span>
      <span>${esc(c.name)} <span style="color:var(--faint);font-size:.78rem">· ${used} งาน</span></span>
      <button class="x-btn" style="opacity:1" onclick="deleteCategory('${c.id}')">✕</button>
    </div>`;
  }).join('');
  $('#modalCard').innerHTML=`
    <div class="modal-head">หมวดหมู่ของ ${esc(p.name)}</div>
    <div class="modal-body">
      <div>${rows||'<span style="color:var(--faint);font-size:.85rem">ยังไม่มีหมวดหมู่</span>'}</div>
      <div class="add-row">
        <input type="text" id="newCat" placeholder="ชื่อหมวดใหม่..." style="flex:1" onkeydown="if(event.key==='Enter')addCategory()">
        <button class="btn btn-primary" onclick="addCategory()">เพิ่ม</button>
      </div>
      <div class="modal-foot"><button class="btn btn-ghost" onclick="closeModal()">เสร็จสิ้น</button></div>
    </div>`;
  openModal();
}
async function addCategory(){
  const el=$('#newCat'); const v=el.value.trim(); if(!v)return;
  const p=activeProject(); const id=uid();
  const c={ id:id, name:v, color:COLORS[p.categories.length%COLORS.length] };
  p.categories.push(c); renderCategoryModal(); renderTopbar();
  try{ await apply('saveCategory',{ id:id, projectId:p.id, name:v, color:c.color }); }catch(e){}
}
async function cycleCatColor(id){
  const c=activeProject().categories.find(x=>x.id===id);
  const idx=COLORS.indexOf(c.color); c.color=COLORS[(idx+1)%COLORS.length];
  renderCategoryModal(); renderBoard();
  try{ await apply('saveCategory',{ id:id, projectId:state.activeProjectId, name:c.name, color:c.color }); }catch(e){}
}
async function deleteCategory(id){
  const p=activeProject();
  if(p.categories.length<=1){toast('ต้องมีอย่างน้อย 1 หมวดหมู่');return;}
  const fallback=p.categories.find(c=>c.id!==id).id;
  state.tasks.forEach(t=>{ if(t.projectId===p.id&&t.categoryId===id)t.categoryId=fallback; });
  p.categories=p.categories.filter(c=>c.id!==id);
  if(state.ui.filterCat===id)state.ui.filterCat='all';
  renderCategoryModal(); renderTopbar(); renderBoard();
  try{ await apply('deleteCategory',{ id:id, fallbackId:fallback }); }catch(e){}
}

/* ========================================================
   DATA: export / import / theme
   ======================================================== */
function openDataModal(){
  const md=state.ui.projectDisplay;
  const seg=[['icon','ไอคอน'],['text','ข้อความ'],['both','ทั้งสอง']]
    .map(([v,l])=>`<button class="${md===v?'on':''}" onclick="setProjectDisplay('${v}')">${l}</button>`).join('');
  $('#modalCard').innerHTML=`
    <div class="modal-head">ตั้งค่า</div>
    <div class="modal-body">
      <div>
        <label>การแสดงโปรเจค (แถบซ้าย)</label>
        <div class="seg">${seg}</div>
      </div>
      <div>
        <label>ผู้ใช้งาน</label>
        <p style="font-size:.86rem;color:var(--muted)">เข้าใช้งานในชื่อ <b>${esc(ME.name)}</b></p>
      </div>
      <div>
        <label>สำรองข้อมูล</label>
        <p style="font-size:.84rem;color:var(--muted);line-height:1.6;margin-bottom:12px">ดาวน์โหลดสำเนาบอร์ดทั้งหมดเป็นไฟล์ JSON (อ่านอย่างเดียว ไม่กระทบฐานข้อมูล)</p>
        <button class="btn btn-primary" onclick="exportData()">⬇ ส่งออก JSON</button>
      </div>
      <div class="modal-foot"><button class="btn btn-ghost" onclick="closeModal()">ปิด</button></div>
    </div>`;
  openModal();
}
function exportData(){
  const blob=new Blob([JSON.stringify(state,null,2)],{type:'application/json'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(blob);
  a.download='nexus-board-'+new Date().toISOString().slice(0,10)+'.json'; a.click();
  toast('ส่งออกข้อมูลแล้ว ✦');
}
function toggleTheme(){
  state.ui.theme=state.ui.theme==='dark'?'light':'dark'; saveUI(); applyTheme();
}
function applyTheme(){
  document.documentElement.setAttribute('data-theme',state.ui.theme);
  $('#themeBtn').textContent=state.ui.theme==='dark'?'🌙':'☀️';
}

/* ========================================================
   MODAL HELPERS
   ======================================================== */
function openModal(){ $('#modal').classList.add('open'); }
function closeModal(){ $('#modal').classList.remove('open'); }
$('#modal').addEventListener('click',e=>{ if(e.target.id==='modal') closeModal(); });
document.addEventListener('keydown',e=>{ if(e.key==='Escape'){ closeModal(); closeDrawer(); closePopover(); closeActivity(); } });

/* ========================================================
   RENDER ALL + INIT
   ======================================================== */
/* ========================================================
   ACTIVITY FEED (who did what)
   ======================================================== */
function actionIcon(a){
  return ({create:'＋',update:'✎',move:'⇄',delete:'🗑',done:'✓',comment:'💬',link:'📎',project:'📁',column:'▦',category:'🏷'}[a.action]||'•');
}
function renderActivity(){
  const el=document.getElementById('activityList'); if(!el) return;
  if(!state.activity.length){ el.innerHTML='<div class="empty-col">ยังไม่มีประวัติการทำงาน</div>'; return; }
  el.innerHTML=state.activity.map(a=>{
    const mine=a.actor===ME.username;
    return `<div class="act-item">
      <div class="act-ic">${actionIcon(a)}</div>
      <div class="act-body">
        <div class="act-top"><b>${esc(mine?'คุณ':(a.actorName||a.actor||'ใครบางคน'))}</b> <span class="act-time">${fmtDateTime(a.createdAt)}</span></div>
        <div class="act-text">${esc(a.summary||'')}</div>
      </div>
    </div>`;
  }).join('');
}
function openActivity(){ renderActivity(); $('#activityScrim').classList.add('open'); $('#activityPanel').classList.add('open'); }
function closeActivity(){ $('#activityScrim').classList.remove('open'); $('#activityPanel').classList.remove('open'); }

function renderAll(){ renderRail(); renderTopbar(); renderBoard(); if(drawerId) renderDrawer(); }

async function init(){
  applyTheme();
  setStatus('saving');
  try{
    await reload();                         // GET full board + activity history from the server
    setStatus('saved');
    setInterval(poll, 10000);               // live-sync other people's changes every 10s
  }catch(e){
    state.projects=[]; state.tasks=[]; renderAll();
    setStatus('error');
    toast('เชื่อมต่อฐานข้อมูลไม่ได้ — ตรวจสอบ connection string และรัน schema แล้วหรือยัง');
  }
}
init();
</script>
</body>
</html>
