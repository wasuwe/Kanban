/* ========================================================
   TASK MUTATIONS
   ======================================================== */
async function setField(id,field,val){
  const t=state.tasks.find(x=>x.id===id); if(!t)return;
  if(t[field]===val) return;
  t[field]=val; t.statusUpdatedAt=new Date().toISOString(); renderAll();
  try{
    const r=await apply('updateTask',{ id:id, rowVersion:t.rowVersion||1, field:field, value:val });
    if(r && r.result){ t.rowVersion=r.result.rowVersion; if(r.result.updatedAt) t.statusUpdatedAt=r.result.updatedAt; }
  }catch(e){ /* conflict triggers reload; other errors are toasted */ }
}
async function toggleSub(taskId, subId){
  const t=state.tasks.find(x=>x.id===taskId); if(!t)return;
  const sb=t.subtasks.find(x=>x.id===subId); if(!sb)return;
  sb.done=!sb.done; renderAll();
  try{ await apply('toggleSubtask',{ id:subId, taskId:taskId, done:sb.done }); }catch(e){}
}
async function delSub(taskId, subId){
  const t=state.tasks.find(x=>x.id===taskId); if(!t)return;
  t.subtasks=t.subtasks.filter(x=>x.id!==subId); renderAll();
  try{ await apply('deleteSubtask',{ id:subId, taskId:taskId }); }catch(e){}
}
async function addSub(taskId, el){
  const v=el.value.trim(); if(!v)return;
  const t=state.tasks.find(x=>x.id===taskId); if(!t)return;
  const sid=uid(); t.subtasks.push({ id:sid, text:v, done:false }); el.value=''; renderAll();
  try{ await apply('addSubtask',{ id:sid, taskId:taskId, text:v }); }catch(e){}
}
async function addComment(taskId, el){
  const v=el.value.trim(); if(!v)return;
  const t=state.tasks.find(x=>x.id===taskId); if(!t)return;
  const cid=uid(); const ts=new Date().toISOString();
  t.comments.push({ id:cid, text:v, timestamp:ts, author:ME.name }); el.value=''; renderAll();
  try{ await apply('addComment',{ id:cid, taskId:taskId, text:v }); }catch(e){}
}
async function addLink(taskId, el){
  const v=el.value.trim(); if(!v)return;
  let name=v, url=v;
  if(v.includes('\\')||/^[a-zA-Z]:/.test(v)){ name=v.split('\\').pop()||v; url='file:///'+v.replace(/\\/g,'/'); }
  else if(!/^https?:\/\//.test(v)){ url='https://'+v; try{name=new URL(url).hostname;}catch(e){} }
  else { try{name=new URL(v).hostname;}catch(e){} }
  const t=state.tasks.find(x=>x.id===taskId); if(!t)return;
  const lid=uid(); t.links.push({ id:lid, name:name, url:url, path:v, isFile:false }); el.value=''; renderAll();
  try{ await apply('addLink',{ id:lid, taskId:taskId, name:name, url:url, path:v, isFile:false }); }catch(e){}
}
async function addFiles(e, taskId){
  const files=e.target.files; const t=state.tasks.find(x=>x.id===taskId); if(!t)return;
  for(const f of files){
    const lid=uid();
    t.links.push({ id:lid, name:f.name, url:URL.createObjectURL(f), path:f.name, isFile:true });
    try{ await apply('addLink',{ id:lid, taskId:taskId, name:f.name, url:'', path:f.name, isFile:true }); }catch(err){}
  }
  renderAll();
}
async function delLink(taskId, linkId){
  const t=state.tasks.find(x=>x.id===taskId); if(!t)return;
  t.links=t.links.filter(l=>l.id!==linkId); renderAll();
  try{ await apply('deleteLink',{ id:linkId, taskId:taskId }); }catch(e){}
}
async function delTask(id){
  if(!confirm('ลบงานนี้?')) return;
  state.tasks=state.tasks.filter(t=>t.id!==id); closeDrawer(); renderAll();
  try{ await apply('deleteTask',{ id:id }); toast('ลบงานแล้ว'); }catch(e){}
}
function copyPath(taskId, linkId){
  const t=state.tasks.find(x=>x.id===taskId); if(!t)return;
  const l=t.links.find(x=>x.id===linkId); if(!l)return;
  const text=(l.path||l.url||'');
  const ta=document.createElement('textarea'); ta.value=text; document.body.appendChild(ta); ta.select();
  try{document.execCommand('copy');}catch(e){} document.body.removeChild(ta); toast('คัดลอกพาธแล้ว ✦');
}

