}

function cardHTML(p,t){
  const cat=catById(p,t.categoryId);
  const subDone=t.subtasks.filter(s=>s.done).length, subTot=t.subtasks.length;
  const subPct=subTot?Math.round(subDone/subTot*100):0;
  const ds=dueState(t.due);
  const tag = cat?`<span class="tag" style="--tag-bg:${shade(cat.color,.14)};--tag-color:${cat.color};--tag-border:${shade(cat.color,.3)}">${esc(cat.name)}</span>`:'';
  const prio = t.priority==='high'?`<span class="prio-flag prio-high">⚑ ${priorityLabel('high')}</span>`
             : t.priority==='low'?`<span class="prio-flag prio-low">${priorityLabel('low')}</span>`:'';
  return `<div class="card ${t.priority==='high'?'urgent':''}" draggable="true" data-id="${t.id}"
     ondragstart="onCardDragStart(event,'${t.id}')" ondragend="onCardDragEnd(event)" onclick="openDrawer('${t.id}')">
    <div class="card-top">${tag}${prio}</div>
    <div class="card-title">${esc(t.text)}</div>
    ${subTot?`<div class="subbar"><i style="width:${subPct}%"></i></div>`:''}
    <div class="card-meta">
      ${t.due?`<span class="meta-pill ${ds}">📅 ${fmtDate(t.due)}</span>`:''}
      ${subTot?`<span class="meta-pill">☑ ${subDone}/${subTot}</span>`:''}
      ${t.comments.length?`<span class="meta-pill">💬 ${t.comments.length}</span>`:''}
      ${t.links.length?`<span class="meta-pill">📎 ${t.links.length}</span>`:''}
    </div>
  </div>`;
}

function composerHTML(p,col){
  const catOpts=p.categories.map(c=>`<option value="${c.id}">${esc(c.name)}</option>`).join('');
  return `<div class="composer">
    <textarea placeholder="งานที่ต้องทำ... (Enter เพื่อสร้าง)" rows="1"
      onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();submitCompose('${col.id}',this)}"></textarea>
    <div class="row">
