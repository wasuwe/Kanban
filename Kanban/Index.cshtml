function startCompose(colId){ composerCol=colId; renderBoard(); }
async function submitCompose(colId,ta){
  const text=ta.value.trim(); if(!text){ composerCol=null; renderBoard(); return; }
  const catEl=ta.closest('.composer').querySelector('#cmpCat');
  const prioEl=ta.closest('.composer').querySelector('#cmpPrio');
  const p=activeProject();
  const id=uid(); const now=new Date().toISOString();
  const order=Math.min(0,...projTasks().filter(t=>t.status===colId).map(t=>t.order??0))-1;
  state.tasks.push({
    id:id, projectId:p.id, text:text, description:'',
    categoryId:catEl.value, priority:prioEl.value, status:colId, due:'', order:order,
    subtasks:[], comments:[], links:[], rowVersion:1, createdAt:now, statusUpdatedAt:now, createdBy:ME.name
  });
  const args={ id:id, projectId:p.id, columnId:colId, categoryId:catEl.value, priority:prioEl.value, text:text, order:order };
  ta.value=''; renderAll();
  try{ await apply('createTask', args); }catch(e){}
  composerCol=colId; renderBoard();
}

/* ========================================================
   DRAG & DROP (cards between/within columns, with ordering)
   ======================================================== */
let dragId=null;
function onCardDragStart(e,id){ dragId=id; e.dataTransfer.effectAllowed='move'; e.target.classList.add('dragging'); }
function onCardDragEnd(e){ e.target.classList.remove('dragging'); document.querySelectorAll('.column').forEach(c=>c.classList.remove('drag-over')); }
function onColDragOver(e,col){ e.preventDefault(); col.classList.add('drag-over'); }
async function onColDrop(e,colId){
  e.preventDefault();
  document.querySelectorAll('.column').forEach(c=>c.classList.remove('drag-over'));
  if(!dragId) return;
  const t=state.tasks.find(x=>x.id===dragId); if(!t){ dragId=null; return; }
  const list=e.currentTarget.querySelector('.card-list');
  const after=getDropIndex(list,e.clientY);
  let colTasks=state.tasks.filter(x=>x.projectId===t.projectId && x.status===colId && x.id!==dragId).sort((a,b)=>(a.order??0)-(b.order??0));
  const fromCol=t.status;
  t.status=colId; t.statusUpdatedAt=new Date().toISOString();
  colTasks.splice(after,0,t);
  colTasks.forEach((x,i)=>x.order=i);
  const movedId=dragId; dragId=null; renderAll();
  try{ await apply('moveTask',{ id:movedId, columnId:colId, fromColumnId:fromCol, orderedIds:colTasks.map(x=>x.id) }); }catch(e){}
}
function getDropIndex(list,y){
  const cards=[...list.querySelectorAll('.card:not(.dragging)')];
  for(let i=0;i<cards.length;i++){
    const r=cards[i].getBoundingClientRect();
    if(y < r.top + r.height/2) return i;
  }
  return cards.length;
}

