    closeModal(); renderAll();
    try{ await apply('saveProject',{ id:p.id, name:name, emoji:modalProj.emoji, color:modalProj.color }); }catch(e){}
  } else {
    const id=uid();
    const p={ id:id, name:name, emoji:modalProj.emoji, color:modalProj.color, columns:[], categories:[] };
    state.projects.push(p); state.activeProjectId=id; closeModal(); renderAll();
    try{
      const r=await apply('saveProject',{ id:id, name:name, emoji:modalProj.emoji, color:modalProj.color, createDefaults:true });
      if(r && r.result){ p.columns=r.result.columns||[]; p.categories=r.result.categories||[]; renderAll(); }
    }catch(e){}
  }
}
async function deleteProject(id){
  if(state.projects.length<=1){ toast('ต้องมีอย่างน้อย 1 โปรเจค'); return; }
  if(!confirm('ลบโปรเจคนี้และงานทั้งหมดในโปรเจค?')) return;
  state.projects=state.projects.filter(p=>p.id!==id);
  state.tasks=state.tasks.filter(t=>t.projectId!==id);
  if(state.activeProjectId===id) state.activeProjectId=state.projects[0].id;
  closeModal(); renderAll();
  try{ await apply('deleteProject',{ id:id }); toast('ลบโปรเจคแล้ว'); }catch(e){}
}

