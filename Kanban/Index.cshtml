@{ Layout = null; }
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nexus Board — Project Command Center</title>
<style>

/* ============ THEME TOKENS ============ */
:root{
  --font-display:'Space Grotesk','Prompt',sans-serif;
  --font-body:'Inter','Prompt',sans-serif;
  --radius-xl:20px; --radius-lg:16px; --radius-md:12px; --radius-sm:9px;
  --accent:#6366f1; --accent-2:#8b5cf6; --accent-glow:rgba(99,102,241,.35);
  --spark:#22d3ee;
  --transition:.22s cubic-bezier(.4,0,.2,1);
}
/* Dark (default) */
html[data-theme="dark"]{
  --bg:#0a0e1a; --bg-grad-1:#10152600; --bg-grad-2:#0a0e1a;
  --panel:#121829; --panel-2:#0f1422; --panel-glass:rgba(20,26,44,.72);
  --card:#161d31; --card-hover:#1b2440;
  --text:#e8edf9; --muted:#94a0bd; --faint:#5c6789;
  --border:rgba(255,255,255,.07); --border-strong:rgba(255,255,255,.13);
  --rail:#0c111f;
  --shadow:0 18px 40px -18px rgba(0,0,0,.65);
  --shadow-soft:0 8px 24px -16px rgba(0,0,0,.6);
  --input-bg:rgba(255,255,255,.04);
}
/* Light */
html[data-theme="light"]{
  --bg:#eef1f7; --bg-grad-1:#ffffff00; --bg-grad-2:#eef1f7;
  --panel:#ffffff; --panel-2:#f5f7fb; --panel-glass:rgba(255,255,255,.82);
  --card:#ffffff; --card-hover:#f7f9fd;
  --text:#0f172a; --muted:#5a6582; --faint:#94a0bd;
  --border:rgba(15,23,42,.09); --border-strong:rgba(15,23,42,.16);
  --rail:#f4f6fb;
  --shadow:0 20px 44px -22px rgba(31,41,80,.30);
  --shadow-soft:0 10px 26px -18px rgba(31,41,80,.28);
  --input-bg:rgba(15,23,42,.03);
}

*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{
  font-family:var(--font-body); color:var(--text);
  background:
    radial-gradient(1200px 600px at 85% -10%, var(--accent-glow), transparent 60%),
    radial-gradient(900px 500px at 0% 110%, rgba(34,211,238,.10), transparent 55%),
    linear-gradient(var(--bg-grad-1),var(--bg-grad-2)),
    var(--bg);
  background-attachment:fixed;
  display:flex; height:100vh; overflow:hidden;
  -webkit-font-smoothing:antialiased;
}
::selection{background:var(--accent-glow)}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,textarea,select{font-family:inherit}
::-webkit-scrollbar{width:9px;height:9px}
::-webkit-scrollbar-thumb{background:var(--border-strong);border-radius:20px}
::-webkit-scrollbar-track{background:transparent}

/* ============ SIDEBAR / PROJECT RAIL ============ */
.rail{
  width:84px; flex-shrink:0; background:var(--rail);
  border-right:1px solid var(--border);
  display:flex; flex-direction:column; align-items:center;
  padding:18px 0; gap:14px; z-index:30;
}
.rail-logo{
  width:46px;height:46px;border-radius:14px;
  background:linear-gradient(135deg,var(--accent),var(--accent-2));
  display:grid;place-items:center;color:#fff;font-weight:700;font-size:1.3rem;
  font-family:var(--font-display);
  box-shadow:0 8px 22px -6px var(--accent-glow);
  flex-shrink:0;
}
.rail-projects{
  flex:1; width:100%; display:flex; flex-direction:column; align-items:center;
  gap:12px; overflow-y:auto; padding:6px 0; scrollbar-width:none;
}
.rail-projects::-webkit-scrollbar{display:none}
.proj-orb{
  position:relative; width:48px;height:48px;flex-shrink:0;
  border-radius:15px; display:grid;place-items:center;
  font-size:1.35rem; cursor:pointer; transition:var(--transition);
  background:var(--panel); border:1px solid var(--border);
}
.proj-orb:hover{transform:translateY(-2px);border-color:var(--border-strong)}
.proj-orb.active{box-shadow:0 0 0 2px var(--bg),0 0 0 4px var(--proj-color)}
.proj-orb .ring{position:absolute;inset:-5px;border-radius:18px;pointer-events:none}
.proj-orb .tip{
  position:absolute; left:60px; top:50%; transform:translateY(-50%) scale(.9);
  background:var(--panel); color:var(--text); border:1px solid var(--border);
  padding:7px 11px; border-radius:10px; font-size:.8rem; font-weight:600;
  white-space:nowrap; opacity:0; pointer-events:none; transition:var(--transition);
  box-shadow:var(--shadow); z-index:50;
}
.proj-orb:hover .tip{opacity:1;transform:translateY(-50%) scale(1)}
.rail-btn{
  width:48px;height:48px;border-radius:15px;flex-shrink:0;
  border:1px dashed var(--border-strong); color:var(--muted);
  font-size:1.4rem; display:grid;place-items:center; transition:var(--transition);
}
.rail-btn:hover{color:var(--accent);border-color:var(--accent);background:var(--input-bg)}
.rail-foot{display:flex;flex-direction:column;gap:10px;align-items:center}
.icon-btn{
  width:44px;height:44px;border-radius:13px;color:var(--muted);
  display:grid;place-items:center;font-size:1.15rem;transition:var(--transition);
}
.icon-btn:hover{background:var(--input-bg);color:var(--text)}

/* --- Rail head (logo + wordmark) --- */
.rail-head{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;flex-shrink:0}
.rail-wordmark{display:none;font-family:var(--font-display);font-weight:700;font-size:1.05rem;letter-spacing:-.3px;white-space:nowrap}
.rail-btn-label{display:none}

/* --- Wide (text/both) rail mode --- */
.rail.wide{width:236px;align-items:stretch;padding:18px 14px}
.rail.wide .rail-head{justify-content:flex-start;padding-left:2px}
.rail.wide .rail-wordmark{display:block}
.rail.wide .rail-projects{align-items:stretch}
.rail.wide .rail-btn{width:100%;height:auto;padding:11px 12px;font-size:.92rem;display:flex;align-items:center;justify-content:center;gap:6px;border-radius:13px}
.rail.wide .rail-btn-label{display:inline}
.rail.wide .rail-foot{flex-direction:row;justify-content:center;gap:8px}

.proj-row{
  display:flex;align-items:center;gap:11px;width:100%;flex-shrink:0;
  padding:10px 11px;border-radius:13px;text-align:left;cursor:pointer;
  background:var(--panel);border:1px solid var(--border);transition:var(--transition);position:relative;
}
.proj-row:hover{border-color:var(--border-strong);transform:translateX(2px)}
.proj-row.active{background:var(--proj-tint);box-shadow:inset 3px 0 0 var(--proj-color)}
.pr-emoji{width:34px;height:34px;border-radius:10px;display:grid;place-items:center;font-size:1.15rem;flex-shrink:0;background:var(--proj-tint);border:1px solid var(--border)}
.pr-body{flex:1;min-width:0;display:flex;flex-direction:column;gap:5px}
.pr-name{font-weight:600;font-size:.9rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.1}
.pr-bar{height:4px;border-radius:20px;background:var(--input-bg);overflow:hidden}
.pr-bar i{display:block;height:100%;border-radius:20px;background:var(--proj-color);transition:width .5s}
.pr-pct{font-size:.72rem;color:var(--muted);font-weight:600;flex-shrink:0}

/* --- Column color dot button --- */
.col-dot-btn{padding:4px;margin:-4px;border-radius:8px;display:grid;place-items:center;transition:var(--transition)}
.col-dot-btn:hover{background:var(--input-bg)}

/* --- Popover --- */
#popScrim{position:fixed;inset:0;z-index:85;display:none}
#popScrim.open{display:block}
.popover{
  position:fixed;z-index:90;background:var(--panel);border:1px solid var(--border-strong);
  border-radius:14px;box-shadow:var(--shadow);padding:13px;min-width:172px;
  animation:pop .18s cubic-bezier(.34,1.56,.64,1);display:none;
}
.popover.open{display:block}
.pop-title{font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--faint);margin-bottom:9px}
.pop-swatches{display:grid;grid-template-columns:repeat(5,1fr);gap:7px}
.pop-swatches button{width:28px;height:28px;border-radius:9px;border:2px solid transparent;transition:var(--transition)}
.pop-swatches button.sel{border-color:var(--text);transform:scale(1.1)}
.pop-swatches button:hover{transform:scale(1.12)}
.pop-del{margin-top:12px;width:100%;padding:9px;border-radius:9px;color:#f87171;font-size:.84rem;font-weight:600;text-align:center;border:1px solid var(--border);transition:var(--transition)}
.pop-del:hover{background:rgba(239,68,68,.12)}
.seg{display:flex;background:var(--input-bg);border:1px solid var(--border);border-radius:11px;padding:3px;gap:3px}
.seg button{flex:1;padding:8px 6px;border-radius:8px;font-size:.82rem;font-weight:600;color:var(--muted);transition:var(--transition)}
.seg button.on{background:linear-gradient(135deg,var(--accent),var(--accent-2));color:#fff;box-shadow:0 6px 14px -8px var(--accent-glow)}

/* ============ MAIN ============ */
.main{flex:1; display:flex; flex-direction:column; min-width:0}

.topbar{
  display:flex;align-items:center;gap:18px;
  padding:18px 28px 14px; flex-wrap:wrap;
}
.proj-heading{display:flex;align-items:center;gap:14px;min-width:0}
.proj-emoji{
  width:50px;height:50px;border-radius:15px;display:grid;place-items:center;
  font-size:1.5rem;flex-shrink:0;
  background:var(--proj-tint); border:1px solid var(--border);
}
.proj-titles h1{
  font-family:var(--font-display);font-size:1.45rem;font-weight:600;
  letter-spacing:-.3px;line-height:1.1; display:flex;align-items:center;gap:8px;
}
.proj-titles h1 .edit-pen{font-size:.85rem;color:var(--faint);opacity:0;transition:var(--transition)}
.proj-heading:hover .edit-pen{opacity:1}
.proj-sub{font-size:.82rem;color:var(--muted);margin-top:3px;display:flex;align-items:center;gap:10px}
.mini-progress{display:flex;align-items:center;gap:8px}
.mini-bar{width:120px;height:6px;border-radius:20px;background:var(--input-bg);overflow:hidden}
.mini-bar i{display:block;height:100%;border-radius:20px;background:linear-gradient(90deg,var(--accent),var(--spark));transition:width .5s ease}

.top-actions{margin-left:auto;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.search-wrap{position:relative}
.search-wrap svg{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--faint)}
.search-bar{
  padding:10px 16px 10px 38px;border-radius:100px;border:1px solid var(--border);
  background:var(--input-bg);color:var(--text);outline:none;width:230px;
  transition:var(--transition);font-size:.88rem;
}
.search-bar:focus{border-color:var(--accent);width:280px;box-shadow:0 0 0 3px var(--accent-glow)}
.search-bar::placeholder{color:var(--faint)}

.chip{
  display:inline-flex;align-items:center;gap:7px;
  padding:9px 14px;border-radius:100px;font-size:.85rem;font-weight:500;
  background:var(--input-bg);border:1px solid var(--border);color:var(--muted);
  transition:var(--transition);
}
.chip:hover{border-color:var(--border-strong);color:var(--text)}
.chip.solid{background:linear-gradient(135deg,var(--accent),var(--accent-2));color:#fff;border:none;box-shadow:0 8px 20px -8px var(--accent-glow)}
.chip select{background:transparent;border:none;outline:none;color:inherit;font-weight:500;cursor:pointer}
.chip select option{background:var(--panel);color:var(--text)}
.save-status{font-size:.8rem;color:var(--muted);font-weight:500;display:inline-flex;align-items:center;gap:6px;padding:0 4px;white-space:nowrap}

/* ============ BOARD ============ */
.board-wrap{flex:1;overflow:auto;padding:8px 28px 28px}
.board{display:flex;gap:18px;align-items:flex-start;min-height:100%;width:max-content;min-width:100%}
.column{
  width:312px;flex-shrink:0;background:var(--panel-glass);
  border:1px solid var(--border);border-radius:var(--radius-xl);
  backdrop-filter:blur(14px);display:flex;flex-direction:column;
  max-height:100%;transition:var(--transition);
  border-top:3px solid var(--col-color);
}
.column.drag-over{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-glow)}
.col-head{display:flex;align-items:center;gap:10px;padding:16px 16px 12px}
.col-dot{width:9px;height:9px;border-radius:50%;background:var(--col-color);box-shadow:0 0 10px var(--col-color)}
.col-name{font-weight:600;font-size:.95rem;font-family:var(--font-display);letter-spacing:.2px;flex:1;
  background:transparent;border:1px solid transparent;border-radius:8px;padding:3px 6px;margin:-3px -6px;color:var(--text);outline:none;min-width:0}
.col-name:focus{border-color:var(--accent);background:var(--input-bg)}
.col-count{font-size:.78rem;font-weight:600;color:var(--muted);background:var(--input-bg);padding:2px 9px;border-radius:20px}
.col-menu{color:var(--faint);font-size:1.1rem;padding:2px 4px;border-radius:6px;transition:var(--transition);opacity:0}
.column:hover .col-menu{opacity:1}
.col-menu:hover{color:var(--text);background:var(--input-bg)}
.card-list{flex:1;overflow-y:auto;padding:4px 12px 12px;display:flex;flex-direction:column;gap:10px;min-height:60px}
.col-add{margin:0 12px 12px;padding:10px;border-radius:var(--radius-md);
  border:1px dashed var(--border-strong);color:var(--muted);font-size:.85rem;font-weight:500;
  display:flex;align-items:center;justify-content:center;gap:6px;transition:var(--transition)}
.col-add:hover{color:var(--accent);border-color:var(--accent);background:var(--input-bg)}

.add-column{
  width:64px;flex-shrink:0;align-self:flex-start;margin-top:2px;
  height:52px;border-radius:var(--radius-lg);border:1px dashed var(--border-strong);
  color:var(--muted);font-size:1.5rem;display:grid;place-items:center;transition:var(--transition);
}
.add-column:hover{color:var(--accent);border-color:var(--accent);background:var(--input-bg);width:120px}

/* ============ CARD ============ */
.card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius-lg);
  padding:13px;cursor:pointer;transition:var(--transition);position:relative;
  box-shadow:var(--shadow-soft);
}
.card:hover{transform:translateY(-2px);border-color:var(--border-strong);background:var(--card-hover);box-shadow:var(--shadow)}
.card.dragging{opacity:.4;transform:rotate(2deg) scale(.98)}
.card.urgent{border-left:3px solid #ef4444}
.card-top{display:flex;align-items:center;gap:6px;margin-bottom:9px;flex-wrap:wrap}
.tag{font-size:.7rem;font-weight:600;padding:3px 9px;border-radius:20px;
  background:var(--tag-bg);color:var(--tag-color);border:1px solid var(--tag-border)}
.prio-flag{font-size:.7rem;font-weight:700;padding:3px 8px;border-radius:20px;display:inline-flex;align-items:center;gap:4px}
.prio-high{background:rgba(239,68,68,.14);color:#f87171}
.prio-medium{background:rgba(245,158,11,.14);color:#fbbf24}
.prio-low{background:rgba(148,163,184,.14);color:#94a3b8}
.card-title{font-size:.95rem;font-weight:500;line-height:1.4;color:var(--text);word-break:break-word}
.card-meta{display:flex;align-items:center;gap:13px;margin-top:11px;flex-wrap:wrap}
.meta-pill{display:inline-flex;align-items:center;gap:5px;font-size:.74rem;color:var(--muted);font-weight:500}
.meta-pill.due-soon{color:#fbbf24}
.meta-pill.overdue{color:#f87171}
.subbar{height:5px;border-radius:20px;background:var(--input-bg);margin-top:10px;overflow:hidden}
.subbar i{display:block;height:100%;border-radius:20px;background:linear-gradient(90deg,var(--accent),var(--spark));transition:width .4s}
.empty-col{text-align:center;color:var(--faint);font-size:.82rem;padding:18px 8px;line-height:1.6}

/* ============ DRAWER ============ */
.scrim{position:fixed;inset:0;background:rgba(2,4,12,.55);backdrop-filter:blur(3px);opacity:0;pointer-events:none;transition:var(--transition);z-index:60}
.scrim.open{opacity:1;pointer-events:auto}
.drawer{
  position:fixed;top:0;right:0;height:100%;width:min(560px,94vw);
  background:var(--panel);border-left:1px solid var(--border);
  transform:translateX(100%);transition:transform .32s cubic-bezier(.4,0,.2,1);
  z-index:70;display:flex;flex-direction:column;box-shadow:-30px 0 60px -30px rgba(0,0,0,.6)
}
.drawer.open{transform:translateX(0)}
.drawer-head{padding:22px 26px 16px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;gap:12px}
.drawer-head .d-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
.d-close{margin-left:auto;width:36px;height:36px;border-radius:11px;display:grid;place-items:center;color:var(--muted);font-size:1.3rem;transition:var(--transition);flex-shrink:0}
.d-close:hover{background:var(--input-bg);color:var(--text)}
.d-title{width:100%;font-family:var(--font-display);font-size:1.3rem;font-weight:600;line-height:1.3;
  background:transparent;border:1px solid transparent;border-radius:10px;padding:6px 8px;margin:-6px -8px;color:var(--text);outline:none;resize:none;overflow:hidden}
.d-title:focus{border-color:var(--accent);background:var(--input-bg)}
.drawer-body{flex:1;overflow-y:auto;padding:22px 26px 40px;display:flex;flex-direction:column;gap:24px}

.field-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.field label{display:block;font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--faint);margin-bottom:7px}
.field select,.field input[type=date]{
  width:100%;padding:10px 12px;border-radius:var(--radius-sm);
  background:var(--input-bg);border:1px solid var(--border);color:var(--text);outline:none;font-size:.88rem;transition:var(--transition)
}
.field select:focus,.field input[type=date]:focus{border-color:var(--accent)}
.field select option{background:var(--panel)}

.sect-title{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--faint);margin-bottom:10px;display:flex;align-items:center;gap:8px}
.sect-title .n{background:var(--input-bg);color:var(--muted);padding:1px 8px;border-radius:20px;font-size:.7rem;letter-spacing:0}

.inline-area{
  width:100%;font-size:.92rem;color:var(--text);resize:vertical;min-height:80px;
  border:1px solid var(--border);background:var(--input-bg);outline:none;
  border-radius:var(--radius-md);padding:12px;line-height:1.6;transition:var(--transition)
}
.inline-area:focus{border-color:var(--accent)}
.inline-area::placeholder{color:var(--faint)}

.seamless{width:100%;background:var(--input-bg);border:1px solid var(--border);padding:10px 12px;
  border-radius:var(--radius-sm);color:var(--text);font-size:.88rem;outline:none;transition:var(--transition)}
.seamless:focus{border-color:var(--accent)}
.seamless::placeholder{color:var(--faint)}
.add-row{display:flex;gap:8px;align-items:center}

.sub-item{display:flex;align-items:flex-start;gap:10px;padding:8px;border-radius:var(--radius-sm);transition:var(--transition)}
.sub-item:hover{background:var(--input-bg)}
.sub-item input[type=checkbox]{margin-top:2px;width:17px;height:17px;cursor:pointer;accent-color:var(--accent)}
.sub-item span{flex:1;line-height:1.5;font-size:.9rem}
.sub-item.done span{text-decoration:line-through;color:var(--faint)}
.x-btn{color:var(--faint);font-size:1rem;opacity:0;transition:var(--transition)}
.sub-item:hover .x-btn,.pill:hover .x-btn{opacity:1}
.x-btn:hover{color:#f87171}

.pill{display:flex;align-items:center;justify-content:space-between;gap:10px;
  background:var(--input-bg);border:1px solid var(--border);padding:9px 12px;border-radius:var(--radius-md);
  font-size:.85rem;transition:var(--transition);margin-bottom:8px}
.pill:hover{border-color:var(--accent)}
.pill .info{display:flex;align-items:center;gap:9px;overflow:hidden;flex:1}
.pill .nm{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500}
.pill .acts{display:flex;gap:4px}
.pill .acts button{width:28px;height:28px;border-radius:7px;color:var(--muted);display:grid;place-items:center;font-size:.9rem;transition:var(--transition)}
.pill .acts button:hover{background:var(--border-strong);color:var(--text)}
.upload{position:relative;overflow:hidden;display:inline-flex}
.upload input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.upload .btn{background:var(--input-bg);border:1px solid var(--border);color:var(--muted);padding:10px 14px;border-radius:var(--radius-sm);font-size:.85rem;font-weight:500;transition:var(--transition)}
.upload:hover .btn{color:var(--text);border-color:var(--border-strong)}

.comment{background:var(--input-bg);padding:11px 13px;border-radius:var(--radius-md);font-size:.85rem;border:1px solid var(--border);margin-bottom:8px;line-height:1.55}
.comment .t{font-size:.7rem;color:var(--faint);display:block;margin-bottom:5px;font-weight:600}

.drawer-foot{padding:14px 26px;border-top:1px solid var(--border);display:flex;align-items:center;gap:10px}
.btn-danger{color:#f87171;font-size:.85rem;font-weight:600;padding:9px 14px;border-radius:var(--radius-sm);transition:var(--transition)}
.btn-danger:hover{background:rgba(239,68,68,.12)}

/* ============ MODAL ============ */
.modal{position:fixed;inset:0;display:none;place-items:center;z-index:80;padding:20px;
  background:rgba(2,4,12,.55);backdrop-filter:blur(4px)}
.modal.open{display:grid}
.modal-card{background:var(--panel);border:1px solid var(--border);border-radius:var(--radius-xl);
  width:min(460px,100%);box-shadow:var(--shadow);overflow:hidden;animation:pop .25s cubic-bezier(.34,1.56,.64,1)}
@@keyframes pop{from{opacity:0;transform:scale(.94) translateY(10px)}to{opacity:1;transform:none}}
.modal-head{padding:20px 22px 4px;font-family:var(--font-display);font-size:1.15rem;font-weight:600}
.modal-body{padding:18px 22px 22px;display:flex;flex-direction:column;gap:16px}
.modal-body label{display:block;font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--faint);margin-bottom:8px}
.modal-body input[type=text]{width:100%;padding:11px 13px;border-radius:var(--radius-sm);background:var(--input-bg);border:1px solid var(--border);color:var(--text);outline:none;font-size:.92rem}
.modal-body input:focus{border-color:var(--accent)}
.emoji-grid,.color-grid{display:flex;flex-wrap:wrap;gap:8px}
.emoji-grid button{width:42px;height:42px;border-radius:11px;font-size:1.3rem;background:var(--input-bg);border:1px solid var(--border);transition:var(--transition)}
.emoji-grid button.sel{border-color:var(--accent);background:var(--accent-glow)}
.emoji-grid button:hover{transform:scale(1.08)}
.color-grid button{width:32px;height:32px;border-radius:50%;border:2px solid transparent;transition:var(--transition)}
.color-grid button.sel{border-color:var(--text);transform:scale(1.12)}
.modal-foot{display:flex;gap:10px;justify-content:flex-end;margin-top:4px}
.btn{padding:10px 18px;border-radius:var(--radius-sm);font-weight:600;font-size:.88rem;transition:var(--transition)}
.btn-ghost{color:var(--muted)}
.btn-ghost:hover{background:var(--input-bg);color:var(--text)}
.btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent-2));color:#fff;box-shadow:0 8px 20px -8px var(--accent-glow)}
.btn-primary:hover{filter:brightness(1.08)}
.cat-row{display:flex;align-items:center;gap:10px;padding:8px;border-radius:var(--radius-sm)}
.cat-row:hover{background:var(--input-bg)}
.cat-swatch{width:14px;height:14px;border-radius:4px;flex-shrink:0}
.cat-row span{flex:1;font-size:.9rem}

/* ============ COMPOSER (quick add bottom of column handled inline) ============ */
.composer{background:var(--card);border:1px solid var(--accent);border-radius:var(--radius-lg);padding:11px;margin-bottom:10px}
.composer textarea{width:100%;background:transparent;border:none;outline:none;color:var(--text);font-size:.92rem;resize:none;line-height:1.4;font-family:inherit;min-height:42px}
.composer textarea::placeholder{color:var(--faint)}
.composer .row{display:flex;gap:8px;margin-top:8px;align-items:center}
.composer select{flex:1;background:var(--input-bg);border:1px solid var(--border);border-radius:8px;padding:6px 8px;color:var(--text);font-size:.8rem;outline:none}
.composer .go{background:linear-gradient(135deg,var(--accent),var(--accent-2));color:#fff;padding:7px 14px;border-radius:8px;font-weight:600;font-size:.82rem}

/* ============ TOAST ============ */
#toast{position:fixed;bottom:26px;left:50%;transform:translateX(-50%) translateY(20px);
  background:var(--panel);border:1px solid var(--border-strong);color:var(--text);
  padding:12px 20px;border-radius:100px;font-size:.85rem;font-weight:500;
  box-shadow:var(--shadow);opacity:0;pointer-events:none;transition:var(--transition);z-index:100}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

.empty-state{flex:1;display:grid;place-items:center;text-align:center;color:var(--muted);padding:40px}
.empty-state .big{font-size:3rem;margin-bottom:14px}
.empty-state h2{font-family:var(--font-display);font-size:1.3rem;color:var(--text);margin-bottom:8px}

.chip.stale{color:#fff;background:linear-gradient(135deg,#f59e0b,#ef4444);border:none;animation:stalePulse 1.6s infinite}
@@keyframes stalePulse{0%,100%{opacity:1}50%{opacity:.65}}
.activity-drawer{width:min(420px,94vw)}
.act-item{display:flex;gap:12px;padding:12px 0;border-bottom:1px solid var(--border)}
.act-ic{width:34px;height:34px;flex-shrink:0;border-radius:10px;display:grid;place-items:center;background:var(--input-bg);border:1px solid var(--border);font-size:.95rem}
.act-body{flex:1;min-width:0}
.act-top{display:flex;justify-content:space-between;align-items:baseline;gap:8px;font-size:.88rem}
.act-time{font-size:.72rem;color:var(--faint);font-weight:500;white-space:nowrap}
.act-text{font-size:.85rem;color:var(--muted);margin-top:3px;line-height:1.5;word-break:break-word}
@@media(max-width:640px){
  .rail{width:64px}
  .topbar{padding:14px 16px 10px}
  .board-wrap{padding:6px 16px 20px}
  .search-bar{width:150px}.search-bar:focus{width:180px}
}
@@media(prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important}}
</style>
</head>
<body>

<!-- ===== PROJECT RAIL ===== -->
<aside class="rail" id="rail">
  <div class="rail-head">
    <div class="rail-logo" title="Nexus Board">N</div>
    <span class="rail-wordmark">Nexus Board</span>
  </div>
  <div class="rail-projects" id="railProjects"></div>
  <button class="rail-btn" title="โปรเจคใหม่" onclick="openProjectModal()">+ <span class="rail-btn-label">โปรเจคใหม่</span></button>
  <div class="rail-foot">
    <button class="icon-btn" id="displayBtn" title="การแสดงโปรเจค" onclick="cycleProjectDisplay()">⊞</button>
    <button class="icon-btn" id="themeBtn" title="สลับธีม" onclick="toggleTheme()">🌙</button>
    <button class="icon-btn" title="ตั้งค่า & สำรองข้อมูล" onclick="openDataModal()">⚙</button>
  </div>
</aside>

<!-- ===== MAIN ===== -->
<main class="main">
  <header class="topbar" id="topbar"></header>
  <div class="board-wrap"><div class="board" id="board"></div></div>
</main>

<!-- ===== DRAWER ===== -->
<div class="scrim" id="scrim" onclick="closeDrawer()"></div>
<aside class="drawer" id="drawer"></aside>
<div class="scrim" id="activityScrim" onclick="closeActivity()"></div>
<aside class="drawer activity-drawer" id="activityPanel">
  <div class="drawer-head">
    <div style="flex:1"><div style="font-family:var(--font-display);font-size:1.2rem;font-weight:600">ประวัติการทำงาน</div><div style="font-size:.8rem;color:var(--muted);margin-top:2px">ใครทำอะไร อัปเดตอัตโนมัติทุก 10 วินาที</div></div>
    <button class="d-close" onclick="closeActivity()">✕</button>
  </div>
  <div class="drawer-body" id="activityList"></div>
</aside>

<!-- ===== MODAL ===== -->
<div class="modal" id="modal"><div class="modal-card" id="modalCard"></div></div>

<!-- ===== POPOVER ===== -->
<div id="popScrim" onclick="closePopover()"></div>
<div class="popover" id="popover"></div>

<div id="toast"></div>

<script>
  window.NX_API = { state: '@Url.Action("GetState","Kanban")', changes: '@Url.Action("GetChanges","Kanban")', apply: '@Url.Action("Apply","Kanban")' };
  window.NX_ME = {
    username: "@Html.Raw(HttpUtility.JavaScriptStringEncode((Session["Username"] ?? "").ToString()))",
    name: "@Html.Raw(HttpUtility.JavaScriptStringEncode(((Session["FullName"] ?? Session["Username"]) ?? "ผู้ใช้").ToString()))"
  };
</script>
<script>
/* ========================================================
   STORAGE — works as downloaded file (localStorage) and
   degrades to in-memory inside sandboxed previews.
   ======================================================== */
const Store = (()=>{
  let mem = {};
  let ok = true;
  try{ const k='__nx_test__'; localStorage.setItem(k,'1'); localStorage.removeItem(k); }
  catch(e){ ok=false; }
  return {
    get(key){ try{ return ok?localStorage.getItem(key):mem[key]??null; }catch(e){ return mem[key]??null; } },
    set(key,val){ try{ ok?localStorage.setItem(key,val):mem[key]=val; }catch(e){ mem[key]=val; } }
  };
})();

const UI_KEY='nexusBoardUI_v1';
const uid = ()=> Date.now().toString(36)+Math.random().toString(36).slice(2,7);

const COLORS=['#6366f1','#8b5cf6','#ec4899','#f43f5e','#f59e0b','#10b981','#06b6d4','#3b82f6','#64748b','#a855f7'];
const EMOJIS=['🚀','💼','🎯','🛠️','📊','💡','🧪','🗄️','🎨','📦','🔧','🌐','📁','⚡','🧩','📅'];

/* ========================================================
   STATE
   ======================================================== */
/* Server API endpoints — injected by the Razor view (with fallback) */
const API = {
  state:   (window.NX_API && window.NX_API.state)   || 'GetState',
  changes: (window.NX_API && window.NX_API.changes) || 'GetChanges',
  apply:   (window.NX_API && window.NX_API.apply)   || 'Apply'
};
const ME = (window.NX_ME) || { username:'', name:'ผู้ใช้' };

function loadUI(){
  let u={}; try{ u=JSON.parse(Store.get(UI_KEY))||{}; }catch(e){}
  return { theme:u.theme||'dark', filterCat:u.filterCat||'all', filterPrio:u.filterPrio||'all',
           projectDisplay:u.projectDisplay||'icon', search:'' };
}
let state = { projects:[], tasks:[], activeProjectId:null, ui:loadUI(), activity:[], lastActivityId:0 };

function applyBoard(data){
  state.projects = (data && data.projects) || [];
  state.tasks    = (data && data.tasks)    || [];
  if(!state.activeProjectId || !state.projects.find(p=>p.id===state.activeProjectId))
    state.activeProjectId = state.projects.length ? state.projects[0].id : null;
}

/* ===== Server data layer (multi-user, granular operations) ===== */
function saveUI(){
  Store.set(UI_KEY, JSON.stringify({
    theme:state.ui.theme, filterCat:state.ui.filterCat,
    filterPrio:state.ui.filterPrio, projectDisplay:state.ui.projectDisplay
  }));
}

async function apiGet(action){
  const res = await fetch(action, { headers:{'Accept':'application/json'} });
  if(!res.ok) throw new Error('HTTP '+res.status);
  return res.json();
}

// Run one operation on the server. Returns { ok, activity, result }.
async function apply(op, args){
  setStatus('saving');
  let res;
  try{
    res = await fetch(API.apply, { method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify(Object.assign({ op:op }, args||{})) });
  }catch(e){ setStatus('offline'); throw e; }

  if(res.status===409){
    setStatus('saved');
    toast('รายการนี้เพิ่งถูกแก้ไขโดยผู้อื่น • กำลังรีเฟรช');
    await reload();
    throw { conflict:true };
  }
  if(!res.ok){
    setStatus('error');
    let m=''; try{ m=(await res.json()).error; }catch(e){}
    toast('บันทึกไม่สำเร็จ' + (m?': '+m:''));
    throw new Error(m||('HTTP '+res.status));
  }
  const data = await res.json();
  if(data && data.activity){ pushActivity(data.activity); state.lastActivityId=Math.max(state.lastActivityId, data.activity.id); }
  setStatus('saved');
  return data || {};
}

/* ----- live activity feed + polling ----- */
function pushActivity(a){
  if(!a || state.activity.some(x=>x.id===a.id)) return;
  state.activity.unshift(a);
  if(state.activity.length>300) state.activity.length=300;
  renderActivity();
}

let _staleByOthers=false;
function isEditing(){
  if(drawerId) return true;
  if($('#modal').classList.contains('open')) return true;
  if(composerCol) return true;
  const a=document.activeElement;
  return !!(a && (a.tagName==='INPUT'||a.tagName==='TEXTAREA'||a.tagName==='SELECT'));
}
async function poll(){
  try{
    const data = await apiGet(API.changes + '?since=' + state.lastActivityId + '&_=' + Date.now());
    const list = (data && data.activities) || [];
    if(list.length){
      list.forEach(a=>{ pushActivity(a); state.lastActivityId=Math.max(state.lastActivityId, a.id); });
      if(list.some(a=>a.actor!==ME.username)){
        if(isEditing()){ _staleByOthers=true; renderStalePill(); }
        else { await reload(); }
      }
    }
  }catch(e){ /* ignore; retry next tick */ }
}

async function reload(){
  const data = await apiGet(API.state);
  applyBoard(data);
  if(data.activities){ state.activity = data.activities.slice(); renderActivity(); }
  if(data.lastActivityId!=null) state.lastActivityId = data.lastActivityId;
  _staleByOthers=false;
  renderAll(); renderStalePill(); setStatus('saved');
}

/* ----- header sync / online indicator ----- */
let _lastStatus='saved';
function setStatus(s){
  _lastStatus=s;
  const el=document.getElementById('saveStatus'); if(!el) return;
  const map={ saving:['◌','กำลังบันทึก…','var(--muted)'],
              saved:['●','ซิงค์แล้ว','#10b981'],
              error:['▲','ผิดพลาด','#f87171'],
              offline:['▲','ออฟไลน์','#f87171'] };
  const m=map[s]||map.saved;
  el.innerHTML='<span style="color:'+m[2]+';font-size:.7rem">'+m[0]+'</span> '+m[1];
}
function renderStalePill(){
  const el=document.getElementById('stalePill'); if(!el) return;
  el.style.display=_staleByOthers?'inline-flex':'none';
}

const $ = s=>document.querySelector(s);
function esc(s){ return (s??'').toString().replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }
function activeProject(){ return state.projects.find(p=>p.id===state.activeProjectId); }
function projTasks(){ return state.tasks.filter(t=>t.projectId===state.activeProjectId); }
function catById(p,id){ return p.categories.find(c=>c.id===id); }
function priorityLabel(p){ return {high:'สูง',medium:'กลาง',low:'ต่ำ'}[p]||'กลาง'; }
function toast(msg){
  const t=$('#toast'); t.textContent=msg; t.classList.add('show');
  clearTimeout(t._tm); t._tm=setTimeout(()=>t.classList.remove('show'),2200);
}
function shade(hex,alpha){
  const n=hex.replace('#',''); const r=parseInt(n.slice(0,2),16),g=parseInt(n.slice(2,4),16),b=parseInt(n.slice(4,6),16);
  return `rgba(${r},${g},${b},${alpha})`;
}
function fmtDate(iso){ if(!iso)return''; const d=new Date(iso); return d.toLocaleDateString('th-TH',{day:'numeric',month:'short'}); }
function fmtDateTime(iso){ const d=new Date(iso); return d.toLocaleDateString('th-TH',{day:'2-digit',month:'short'})+' '+d.toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'}); }
function dueState(iso){
  if(!iso) return '';
  const today=new Date(); today.setHours(0,0,0,0);
  const d=new Date(iso); d.setHours(0,0,0,0);
  const diff=(d-today)/86400000;
  if(diff<0) return 'overdue';
  if(diff<=2) return 'due-soon';
  return '';
}

/* ========================================================
   RENDER: RAIL
   ======================================================== */
function renderRail(){
  const mode=state.ui.projectDisplay;            // 'icon' | 'text' | 'both'
  const rail=$('#rail');
  rail.classList.toggle('wide', mode!=='icon');
  $('#displayBtn').textContent = mode==='icon'?'⊞':(mode==='text'?'Aa':'⊟');
  $('#displayBtn').title = 'การแสดงโปรเจค: '+(mode==='icon'?'ไอคอน':mode==='text'?'ข้อความ':'ไอคอน + ข้อความ');

  const wrap=$('#railProjects');
  wrap.innerHTML = state.projects.map(p=>{
    const tasks=state.tasks.filter(t=>t.projectId===p.id);
    const lastCol=p.columns&&p.columns.length?p.columns[p.columns.length-1].id:null;
    const done=tasks.filter(t=>t.status===lastCol).length;
    const pct=tasks.length?Math.round(done/tasks.length*100):0;
    const active=p.id===state.activeProjectId;
    const C=p.color;

    if(mode==='icon'){
      const ring=`conic-gradient(${C} ${pct*3.6}deg, ${shade(C,.18)} 0deg)`;
      return `<div class="proj-orb ${active?'active':''}" style="--proj-color:${C};background:${active?shade(C,.16):''}"
        onclick="switchProject('${p.id}')" oncontextmenu="event.preventDefault();editProject('${p.id}')" title="${esc(p.name)}">
        ${active?`<div class="ring" style="background:${ring};-webkit-mask:radial-gradient(circle,transparent 62%,#000 63%);mask:radial-gradient(circle,transparent 62%,#000 63%)"></div>`:''}
        <span>${esc(p.emoji)}</span>
        <div class="tip">${esc(p.name)} · ${pct}%</div>
      </div>`;
    }
    // text / both
    const emojiEl = mode==='both' ? `<span class="pr-emoji">${esc(p.emoji)}</span>` : '';
    return `<div class="proj-row ${active?'active':''}" style="--proj-color:${C};--proj-tint:${shade(C,.16)}"
      onclick="switchProject('${p.id}')" oncontextmenu="event.preventDefault();editProject('${p.id}')" title="คลิกขวาเพื่อแก้ไข">
      ${emojiEl}
      <div class="pr-body">
        <span class="pr-name">${esc(p.name)}</span>
        <span class="pr-bar"><i style="width:${pct}%"></i></span>
      </div>
      <span class="pr-pct">${pct}%</span>
    </div>`;
  }).join('');
}

function cycleProjectDisplay(){
  const order=['icon','both','text'];
  const i=order.indexOf(state.ui.projectDisplay);
  state.ui.projectDisplay=order[(i+1)%order.length];
  saveUI(); renderRail();
  toast('แสดงโปรเจคแบบ: '+({icon:'ไอคอน',text:'ข้อความ',both:'ไอคอน + ข้อความ'}[state.ui.projectDisplay]));
}
function setProjectDisplay(mode){
  state.ui.projectDisplay=mode; saveUI(); renderRail();
  if($('#modal').classList.contains('open')) openDataModal();
}

/* ========================================================
   RENDER: TOPBAR
   ======================================================== */
function renderTopbar(){
  const p=activeProject();
  const tasks=projTasks();
  const lastCol=p.columns&&p.columns.length?p.columns[p.columns.length-1].id:null;
  const done=tasks.filter(t=>t.status===lastCol).length;
  const pct=tasks.length?Math.round(done/tasks.length*100):0;
  const catOpts = `<option value="all">ทุกหมวด</option>`+p.categories.map(c=>`<option value="${c.id}" ${state.ui.filterCat===c.id?'selected':''}>${esc(c.name)}</option>`).join('');
  const prioOpts = ['all','high','medium','low'].map(v=>`<option value="${v}" ${state.ui.filterPrio===v?'selected':''}>${v==='all'?'ทุกระดับ':'ความสำคัญ '+priorityLabel(v)}</option>`).join('');

  $('#topbar').innerHTML = `
    <div class="proj-heading" style="--proj-tint:${shade(p.color,.14)}">
      <div class="proj-emoji">${esc(p.emoji)}</div>
      <div class="proj-titles">
        <h1>${esc(p.name)} <span class="edit-pen" onclick="editProject('${p.id}')" title="แก้ไขโปรเจค" style="cursor:pointer">✎</span></h1>
        <div class="proj-sub">
          <span>${tasks.length} งาน · เสร็จ ${done}</span>
          <span class="mini-progress"><span class="mini-bar"><i style="width:${pct}%"></i></span> ${pct}%</span>
        </div>
      </div>
    </div>
    <div class="top-actions">
      <div class="search-wrap">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        <input class="search-bar" id="searchInput" placeholder="ค้นหางาน..." value="${esc(state.ui.search||'')}" oninput="onSearch(this.value)">
      </div>
      <span class="chip"><span style="color:var(--faint)">🏷</span><select onchange="setFilter('filterCat',this.value)">${catOpts}</select></span>
      <span class="chip"><span style="color:var(--faint)">⚑</span><select onchange="setFilter('filterPrio',this.value)">${prioOpts}</select></span>
      <button class="chip" onclick="openCategoryModal()" title="จัดการหมวดหมู่">หมวดหมู่</button>
      <button class="chip" onclick="openActivity()" title="ประวัติการทำงาน">🕘 ประวัติ</button>
      <button id="stalePill" class="chip stale" style="display:none" onclick="reload()" title="มีการอัปเดตจากผู้อื่น">↻ มีอัปเดตใหม่</button>
      <span id="saveStatus" class="save-status" title="สถานะการซิงค์">● ซิงค์แล้ว</span>
    </div>`;
  if(_lastStatus) setStatus(_lastStatus);
  renderStalePill();
}

/* ========================================================
   RENDER: BOARD
   ======================================================== */
let composerCol=null;
function renderBoard(){
  const p=activeProject();
  const q=(state.ui.search||'').toLowerCase().trim();
  let tasks=projTasks().filter(t=>{
    if(state.ui.filterCat!=='all' && t.categoryId!==state.ui.filterCat) return false;
    if(state.ui.filterPrio!=='all' && t.priority!==state.ui.filterPrio) return false;
    if(q){
      const cat=catById(p,t.categoryId);
      const hay=(t.text+' '+t.description+' '+(cat?cat.name:'')+' '+t.subtasks.map(s=>s.text).join(' ')).toLowerCase();
      if(!hay.includes(q)) return false;
    }
    return true;
  });

  const board=$('#board');
  board.innerHTML = p.columns.map(col=>{
    const colTasks = tasks.filter(t=>t.status===col.id).sort((a,b)=>(a.order??0)-(b.order??0));
    const cards = colTasks.map(t=>cardHTML(p,t)).join('') ||
      `<div class="empty-col">ลากการ์ดมาวาง<br>หรือกด + เพื่อเพิ่มงาน</div>`;
    const composer = composerCol===col.id ? composerHTML(p,col) : '';
    return `<div class="column" data-col="${col.id}" style="--col-color:${col.color}"
       ondragover="onColDragOver(event,this)" ondragleave="this.classList.remove('drag-over')" ondrop="onColDrop(event,'${col.id}')">
      <div class="col-head">
        <button class="col-dot-btn" onclick="openColumnPopover(event,'${col.id}')" title="เปลี่ยนสีคอลัมน์"><span class="col-dot"></span></button>
        <input class="col-name" value="${esc(col.name)}" title="คลิกเพื่อแก้ชื่อ"
          onchange="renameColumn('${col.id}',this.value)"
          onkeydown="if(event.key==='Enter')this.blur()" onclick="event.stopPropagation()">
        <span class="col-count">${colTasks.length}</span>
